{
  "require": {
    "phpoffice/phpspreadsheet": "^4.2",
    "dompdf/dompdf": "^3.1",
    "mpdf/mpdf": "^8.2",
    "vlucas/phpdotenv": "^5.6",
    "phpmailer/phpmailer": "^7.0",
    "minishlink/web-push": "^10.0",
    "smalot/pdfparser": "^2.12",
    "sentry/sentry": "^4.20"
  },
  "autoload": {
    "psr-4": {
      "App\\": "App/"
    }
  },
  "autoload-dev": {
    "psr-4": {
      "Tests\\": "tests/"
    }
  },
  "require-dev": {
    "pestphp/pest": "^3.8"
  },
  "config": {
    "allow-plugins": {
      "pestphp/pest-plugin": true
    }
  }
}
