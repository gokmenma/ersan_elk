RewriteEngine on

# Hassas dosyalara doğrudan erişimi engelle
<Files ".env">
    Require all denied
</Files>
<Files "*.log">
    Require all denied
</Files>
<Files "*.bak">
    Require all denied
</Files>
<FilesMatch "^(composer\.(json|lock)|package\.json|yarn\.lock)$">
    Require all denied
</FilesMatch>

# Eğer dizin değilse ve dosya varsa
RewriteCond %{REQUEST_FILENAME} !-d
RewriteCond %{REQUEST_FILENAME}.php -f

# .php uzantısını gizle
RewriteRule ^(.*)$ $1.php [L]
RewriteRule ^evrak.pdf$ goruntule.php [QSA,L]

# Belirli bir desenle eşleşen URL'leri .php dosyasına yönlendir
RewriteRule ^([a-z]+)\/?$ $1.php [NC,L]

# Güvenlik Header'ları
# <IfModule mod_headers.c>
#     Header always set X-Frame-Options "DENY"
#     Header always set X-Content-Type-Options "nosniff"
#     Header always set Referrer-Policy "strict-origin-when-cross-origin"
#     Header always set Permissions-Policy "geolocation=(), camera=(), microphone=()"
#     Header always set X-XSS-Protection "1; mode=block"
# </IfModule>

# Server imzasını gizle
ServerSignature Off